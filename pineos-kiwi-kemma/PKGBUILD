pkgname=pineos-kiwi-kemma
pkgver=0.2.3
pkgrel=1
pkgdesc="macOS-inspired enhancements for GNOME Shell (PineOS Edition, originally by kem-a)"
arch=('any')
url="https://github.com/The-Pine-Project/kiwi-kemma"
license=('GPL3')
depends=('gnome-shell')
makedepends=('git')
source=("git+https://github.com/The-Pine-Project/kiwi-kemma.git")
sha256sums=('SKIP')

package() {
    cd kiwi-kemma
    _uuid=$(grep -Po '(?<="uuid": ")[^"]*' metadata.json)
    install -d "$pkgdir/usr/share/gnome-shell/extensions/${_uuid}"
    cp -r * "$pkgdir/usr/share/gnome-shell/extensions/${_uuid}/"
}
